pipeline {
    agent any

    environment {
        VENV = "venv"
    }

    stages {
        stage('Setup Environment') {
            steps {
                echo "🔧 Setting up Python & Poetry"
                sh '''
                    python3 -m venv $VENV
                    source $VENV/bin/activate
                    pip install --upgrade pip
                    pip install poetry
                    poetry install
                '''
            }
        }

        stage('Run Tests') {
            steps {
                echo "🧪 Running tests (if any)"
                sh '''
                    source $VENV/bin/activate
                    if poetry run pytest ; then
                        echo "✅ Tests passed"
                    else
                        echo "⚠️ Tests failed or no tests found"
                    fi
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "🐳 Building Docker image"
                sh '''
                    docker build -t fastapi-template:latest .
                    docker images | grep fastapi-template
                '''
            }
        }
    }
}
